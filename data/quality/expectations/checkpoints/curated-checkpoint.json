{
  "name": "curated_layer_checkpoint",
  "config_version": 1.0,
  "class_name": "SimpleCheckpoint",
  "module_name": "great_expectations.checkpoint",
  "run_name_template": "%Y%m%d-%H%M%S-curated-layer",
  "expectation_suite_name": "curated_layer",
  "action_list": [
    {
      "name": "store_validation_result",
      "action": {
        "class_name": "StoreValidationResultAction"
      }
    },
    {
      "name": "store_evaluation_params",
      "action": {
        "class_name": "StoreEvaluationParametersAction"
      }
    },
    {
      "name": "update_data_docs",
      "action": {
        "class_name": "UpdateDataDocsAction",
        "site_names": []
      }
    },
    {
      "name": "send_slack_notification_on_failure",
      "action": {
        "class_name": "SlackNotificationAction",
        "slack_webhook": "${SLACK_WEBHOOK_URL}",
        "notify_on": "failure",
        "notify_with": ["local_site"],
        "renderer": {
          "module_name": "great_expectations.render.renderer.slack_renderer",
          "class_name": "SlackRenderer"
        }
      }
    },
    {
      "name": "send_pagerduty_alert_on_failure",
      "action": {
        "class_name": "PagerdutyAlertAction",
        "api_key": "${PAGERDUTY_API_KEY}",
        "routing_key": "${PAGERDUTY_ROUTING_KEY}",
        "notify_on": "failure"
      }
    },
    {
      "name": "block_promotion_on_failure",
      "action": {
        "class_name": "StoreValidationResultAction",
        "target_store_name": "blocked_promotions_store"
      }
    }
  ],
  "validations": [
    {
      "batch_request": {
        "datasource_name": "iceberg_trino",
        "data_connector_name": "default_inferred_data_connector_name",
        "data_asset_name": "lakehouse.curated.fact_events",
        "data_connector_query": {
          "index": -1
        }
      },
      "expectation_suite_name": "curated_layer"
    },
    {
      "batch_request": {
        "datasource_name": "iceberg_trino",
        "data_connector_name": "default_inferred_data_connector_name",
        "data_asset_name": "lakehouse.curated.dim_entities",
        "data_connector_query": {
          "index": -1
        }
      },
      "expectation_suite_name": "curated_layer"
    },
    {
      "batch_request": {
        "datasource_name": "iceberg_trino",
        "data_connector_name": "default_inferred_data_connector_name",
        "data_asset_name": "lakehouse.curated.mart_analytics",
        "data_connector_query": {
          "index": -1
        }
      },
      "expectation_suite_name": "curated_layer"
    }
  ],
  "meta": {
    "great_expectations_version": "0.18.x",
    "description": "Checkpoint for curated (gold) layer Iceberg tables. Strictest quality gate — enforces SLA-level constraints, statistical distribution checks, and GDPR compliance rules. Blocks promotion to production if any validation fails. Triggers PagerDuty on failure.",
    "layer": "curated",
    "owner": "data-stewards",
    "trigger": "post-dbt-curated",
    "on_failure": "block_promotion_and_page"
  }
}
