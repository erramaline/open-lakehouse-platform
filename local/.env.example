# =============================================================================
# Open Lakehouse Platform — Local Development Environment Variables
# =============================================================================
# USAGE:
#   cp local/.env.example local/.env
#   Edit local/.env with your own secrets (never commit .env to git)
#
# FORMAT (per variable):
#   # Description          | Services using it
#   VARIABLE=example_value
#
# All values below are FAKE placeholders — replace before running.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# PROJECT
# ─────────────────────────────────────────────────────────────────────────────

# Docker Compose project name (used as prefix for container/volume names)
# Services: all
COMPOSE_PROJECT_NAME=lakehouse

# ─────────────────────────────────────────────────────────────────────────────
# POSTGRESQL 16 — Shared backend
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL superuser (used only for init; not exposed to services)
# Services: postgresql
POSTGRES_USER=lakehouse_admin
POSTGRES_PASSWORD=change_me_postgres_superuser_pw_32chars

# Per-service database names (created by init-databases.sh)
# Services: postgresql init script
KEYCLOAK_DB=keycloak
POLARIS_DB=polaris
NESSIE_DB=nessie
RANGER_DB=ranger
AIRFLOW_DB=airflow
OPENMETADATA_DB=openmetadata

# Per-service database users and passwords
# Services: keycloak, polaris, nessie, ranger-admin, airflow-*, openmetadata-server
KEYCLOAK_DB_USER=keycloak_user
KEYCLOAK_DB_PASSWORD=change_me_keycloak_db_pw_32chars

POLARIS_DB_USER=polaris_user
POLARIS_DB_PASSWORD=change_me_polaris_db_pw_32chars

NESSIE_DB_USER=nessie_user
NESSIE_DB_PASSWORD=change_me_nessie_db_pw_32chars

RANGER_DB_USER=ranger_user
RANGER_DB_PASSWORD=change_me_ranger_db_pw_32chars

AIRFLOW_DB_USER=airflow_user
AIRFLOW_DB_PASSWORD=change_me_airflow_db_pw_32chars

OPENMETADATA_DB_USER=openmetadata_user
OPENMETADATA_DB_PASSWORD=change_me_openmetadata_db_pw_32chars

# ─────────────────────────────────────────────────────────────────────────────
# PGBOUNCER — Connection pooler in front of PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────

# PgBouncer pool settings (for reference; bitnami/pgbouncer reads POSTGRES_* vars)
# Services: pgbouncer
PGBOUNCER_MAX_CLIENT_CONN=500
PGBOUNCER_DEFAULT_POOL_SIZE=20
PGBOUNCER_PORT=6432

# ─────────────────────────────────────────────────────────────────────────────
# MINIO — Distributed object storage (4 nodes, EC:4)
# ─────────────────────────────────────────────────────────────────────────────

# MinIO root credentials (equivalent to AWS access key / secret key)
# Services: minio-1 minio-2 minio-3 minio-4, scripts/bootstrap/03-init-minio.sh
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=change_me_minio_root_secret_32chars

# MinIO service account for Polaris (bucket: iceberg/)
# Set by 03-init-minio.sh, read by polaris
MINIO_POLARIS_ACCESS_KEY=polaris_svc_key
MINIO_POLARIS_SECRET_KEY=change_me_polaris_minio_secret_32chars

# MinIO service account for Airflow/ingestion (buckets: raw/ staging/)
# Set by 03-init-minio.sh, read by airflow-*
MINIO_INGESTION_ACCESS_KEY=ingestion_svc_key
MINIO_INGESTION_SECRET_KEY=change_me_ingestion_minio_secret_32chars

# MinIO service account for OTel/audit (bucket: audit/)
# Set by 03-init-minio.sh, read by otel-collector
MINIO_AUDIT_ACCESS_KEY=audit_svc_key
MINIO_AUDIT_SECRET_KEY=change_me_audit_minio_secret_32chars

# ─────────────────────────────────────────────────────────────────────────────
# OPENBAO — Secrets manager (Raft HA, 3 nodes)
# ─────────────────────────────────────────────────────────────────────────────

# Root token — ONLY for local bootstrap; rotated after initialization
# Services: scripts/bootstrap/01-init-openbao.sh (init only)
OPENBAO_DEV_ROOT_TOKEN=change_me_openbao_root_token_local_only

# Primary node address (used by other services and bootstrap scripts)
# Services: all services that read secrets from OpenBao
OPENBAO_ADDR=http://openbao-1:8200

# ─────────────────────────────────────────────────────────────────────────────
# KEYCLOAK — OIDC Identity Provider
# ─────────────────────────────────────────────────────────────────────────────

# Keycloak bootstrap admin credentials (rotate after first login)
# Services: keycloak, scripts/bootstrap/02-init-keycloak.sh
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak_admin_pw_32chars

# Realm name (imported from realm-export.json)
# Services: keycloak, trino-gateway, airflow-*, openmetadata-server, grafana
KEYCLOAK_REALM=lakehouse

# Internal URL used by services for OIDC discovery
# Services: trino-gateway, airflow-*, openmetadata-server, grafana
KEYCLOAK_URL=http://keycloak:8080

# Client secrets for OIDC clients (must match realm-export.json)
# Services: trino-gateway, airflow-webserver, openmetadata-server, grafana
KEYCLOAK_TRINO_CLIENT_SECRET=change_me_trino_oidc_client_secret
KEYCLOAK_AIRFLOW_CLIENT_SECRET=change_me_airflow_oidc_client_secret
KEYCLOAK_OPENMETADATA_CLIENT_SECRET=change_me_openmetadata_oidc_client_secret
KEYCLOAK_GRAFANA_CLIENT_SECRET=change_me_grafana_oidc_client_secret
KEYCLOAK_MINIO_CLIENT_SECRET=change_me_minio_oidc_client_secret

# ─────────────────────────────────────────────────────────────────────────────
# APACHE POLARIS 1.2.0 — Iceberg REST Catalog (production)
# ─────────────────────────────────────────────────────────────────────────────

# Polaris bootstrap admin credentials
# Services: polaris, scripts/bootstrap/04-init-polaris.sh
POLARIS_BOOTSTRAP_ADMIN_CLIENT_ID=polaris-root-admin
POLARIS_BOOTSTRAP_ADMIN_SECRET=change_me_polaris_admin_secret_32chars

# OAuth2 credentials for Trino to authenticate against Polaris
# Services: trino-coordinator, trino-worker-*
POLARIS_TRINO_CLIENT_ID=trino-svc
POLARIS_TRINO_CLIENT_SECRET=change_me_polaris_trino_secret_32chars

# OAuth2 credentials for Airflow pipelines
# Services: airflow-*
POLARIS_AIRFLOW_CLIENT_ID=airflow-svc
POLARIS_AIRFLOW_CLIENT_SECRET=change_me_polaris_airflow_secret_32chars

# ─────────────────────────────────────────────────────────────────────────────
# PROJECT NESSIE — Dev/CI Iceberg catalog
# ─────────────────────────────────────────────────────────────────────────────

# Nessie authentication token (Bearer)
# Services: nessie, trino-coordinator (for nessie catalog), airflow-*
NESSIE_AUTH_TOKEN=change_me_nessie_bearer_token_32chars

# ─────────────────────────────────────────────────────────────────────────────
# APACHE RANGER 2.6.0 — Policy Engine
# ─────────────────────────────────────────────────────────────────────────────

# Ranger admin UI password
# Services: ranger-admin, scripts/bootstrap/05-init-ranger.sh
RANGER_ADMIN_PASSWORD=change_me_ranger_admin_pw_32chars

# Ranger URL used by Trino plugin
# Services: trino-coordinator, trino-worker-*
RANGER_URL=http://ranger-admin:6080

# Ranger service name for Trino (must match policy in Ranger)
RANGER_TRINO_SERVICE_NAME=lakehouse_trino

# ─────────────────────────────────────────────────────────────────────────────
# TRINO 479 — MPP Query Engine
# ─────────────────────────────────────────────────────────────────────────────

# Shared internal authentication secret for Trino cluster
# Services: trino-coordinator, trino-worker-1, trino-worker-2, trino-worker-3
TRINO_INTERNAL_SHARED_SECRET=change_me_trino_shared_secret_32chars_min

# JVM heap size per Trino node (adapt to available RAM; 8G for prod-like)
# Services: trino-coordinator, trino-worker-*
TRINO_JVM_HEAP=4G

# Trino coordinator URL used by gateway
# Services: trino-gateway
TRINO_COORDINATOR_URL=http://trino-coordinator:8080

# ─────────────────────────────────────────────────────────────────────────────
# TRINO GATEWAY
# ─────────────────────────────────────────────────────────────────────────────

# Gateway JWT signing secret (for Keycloak token validation)
# Services: trino-gateway
TRINO_GATEWAY_BACKEND_JDBC_URL=jdbc:postgresql://pgbouncer:6432/trino_gateway
TRINO_GATEWAY_DB_USER=trino_gw_user
TRINO_GATEWAY_DB_PASSWORD=change_me_trino_gateway_db_pw

# ─────────────────────────────────────────────────────────────────────────────
# APACHE AIRFLOW 2.10.x — Pipeline Orchestrator
# ─────────────────────────────────────────────────────────────────────────────

# Fernet key — MUST be a valid 32-byte base64-encoded key
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Services: airflow-webserver, airflow-scheduler, airflow-worker
AIRFLOW_FERNET_KEY=change_me_fernet_key_base64_encoded_32bytes==

# Flask/Airflow webserver secret key
# Services: airflow-webserver
AIRFLOW_SECRET_KEY=change_me_airflow_flask_secret_key_32chars

# Airflow admin user for UI
# Services: airflow-webserver (created on init)
AIRFLOW_ADMIN_USER=airflow_admin
AIRFLOW_ADMIN_PASSWORD=change_me_airflow_admin_pw_32chars
AIRFLOW_ADMIN_EMAIL=admin@lakehouse.local

# ─────────────────────────────────────────────────────────────────────────────
# REDIS — Celery broker for Airflow
# ─────────────────────────────────────────────────────────────────────────────

# Redis password (AUTH command)
# Services: redis, airflow-webserver, airflow-scheduler, airflow-worker
REDIS_PASSWORD=change_me_redis_password_32chars

# ─────────────────────────────────────────────────────────────────────────────
# OPENMETADATA 1.12.x — Data Catalog & Lineage
# ─────────────────────────────────────────────────────────────────────────────

# OpenMetadata JWT config (RSA key pair — generate via scripts/bootstrap/)
# Services: openmetadata-server, openmetadata-ingestion
OPENMETADATA_JWT_ISSUER=open-metadata.org
# These are file paths inside the container; keys mounted via volumes
OPENMETADATA_PRIVATE_KEY_PATH=/etc/openmetadata/jwt/private_key.der
OPENMETADATA_PUBLIC_KEY_PATH=/etc/openmetadata/jwt/public_key.der

# Admin email for bootstrap
# Services: openmetadata-server
OPENMETADATA_ADMIN_EMAIL=admin@lakehouse.local

# ─────────────────────────────────────────────────────────────────────────────
# ELASTICSEARCH — OpenMetadata search backend
# ─────────────────────────────────────────────────────────────────────────────

# Elasticsearch built-in user password
# Services: elasticsearch, openmetadata-server
ELASTIC_PASSWORD=change_me_elastic_password_32chars

# ─────────────────────────────────────────────────────────────────────────────
# GRAFANA — Observability dashboard
# ─────────────────────────────────────────────────────────────────────────────

# Grafana admin credentials
# Services: grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_admin_pw_32chars
GRAFANA_SECRET_KEY=change_me_grafana_secret_key_32chars

# ─────────────────────────────────────────────────────────────────────────────
# DOCLING — Document ingestion API
# ─────────────────────────────────────────────────────────────────────────────

# API key for Docling REST service (internal use)
# Services: docling-api, airflow-worker (calling docling)
DOCLING_API_KEY=change_me_docling_internal_api_key

# ─────────────────────────────────────────────────────────────────────────────
# TLS / CERTIFICATES (local dev)
# ─────────────────────────────────────────────────────────────────────────────

# Directory where 00-init-tls.sh writes generated certs
# Services: all mTLS-enabled services (volume mount)
LOCAL_TLS_DIR=./volumes/tls

# ─────────────────────────────────────────────────────────────────────────────
# SOLR — Ranger audit backend
# ─────────────────────────────────────────────────────────────────────────────

# Solr security configuration
# Services: solr, ranger-admin
SOLR_RANGER_COLLECTION=ranger_audits
