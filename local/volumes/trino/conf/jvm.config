# =============================================================================
# Trino 479 — JVM configuration (local development)
# Tuned for a machine with 16–32 GB RAM; adjust TRINO_JVM_HEAP in .env
# =============================================================================

# Heap size — set via TRINO_JVM_HEAP env var (default: 4G for local dev)
-Xmx${TRINO_JVM_HEAP:-4G}
-Xms${TRINO_JVM_HEAP:-4G}

# G1GC tuning (recommended by Trino documentation)
-XX:+UseG1GC
-XX:G1HeapRegionSize=32M
-XX:+ExplicitGCInvokesConcurrent
-XX:+HeapDumpOnOutOfMemoryError
-XX:+ExitOnOutOfMemoryError
-XX:ReservedCodeCacheSize=512M
-XX:PerMethodRecompilationCutoff=10000
-XX:PerBytecodeRecompilationCutoff=10000

# Ergonomics
-Djdk.attach.allowAttachSelf=true
-Djdk.nio.maxCachedBufferSize=2000000

# Verbose GC logging (useful for local debugging)
-Xlog:gc*:file=/var/trino/logs/gc.log:time,uptime:filecount=5,filesize=50m

# Off-heap memory for unsafe operations
-XX:MaxDirectMemorySize=2048m
