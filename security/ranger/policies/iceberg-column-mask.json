          "accesses": [{ "type": "select", "isAllowed": true }],
          "conditions": [],
          "_comment": "ssn → NULL for everyone except platform-admin"
        },
        {
          "dataMaskInfo": { "dataMaskType": "NONE" },
          "groups": ["platform-admins"],
          "users": [],
          "accesses": [{ "type": "select", "isAllowed": true }],
          "conditions": [],
          "_comment": "ssn → full for platform-admins"
